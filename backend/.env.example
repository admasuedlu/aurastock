# For production set DEBUG=False, a long random SECRET_KEY (the app refuses to
# boot with the dev default when DEBUG=False), and your real host(s).
DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated allowed browser origins for the API (CORS). Only enforced when
# DEBUG=False; in dev all origins are allowed.
CORS_ALLOWED_ORIGINS=

# --- Production security (only applied when DEBUG=False) ---
# HTTPS redirect + HSTS + secure cookies turn on automatically. Override only if
# TLS is terminated somewhere that makes the redirect loop, or to ramp up HSTS.
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# Shared secret the sandbox payment provider signs/verifies webhooks with.
PAYMENTS_SANDBOX_SECRET=change-me

DB_NAME=aurastock
DB_USER=aurastock
DB_PASSWORD=aurastock
DB_HOST=db
DB_PORT=5432

REDIS_URL=redis://redis:6379/0

JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# Only read when USE_SQLITE is not set (local dev uses the console backend instead)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=notifications@aurastock.local
